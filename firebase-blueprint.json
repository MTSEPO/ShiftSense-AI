{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and subscription status",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "isPro": { "type": "boolean" },
        "requestCount": { "type": "integer" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "isPro", "requestCount"]
    },
    "Analysis": {
      "title": "Analysis",
      "description": "Vehicle analysis reports generated by the user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "vehicles": {
          "type": "array",
          "items": { "type": "object" }
        },
        "context": { "type": "string" },
        "report": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "vehicles", "report", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/analyses/{analysisId}": {
      "schema": "Analysis",
      "description": "Saved vehicle analysis reports"
    }
  }
}
