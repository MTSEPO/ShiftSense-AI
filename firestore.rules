rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required, email format)
    //   - isPro: bool (required)
    //   - requestCount: int (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: analyses
    // Document ID: {analysisId}
    // Fields:
    //   - userId: string (required)
    //   - vehicles: list (required)
    //   - context: string (optional)
    //   - report: string (required)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "tsepom@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'isPro', 'requestCount']) &&
             data.uid is string &&
             data.email is string &&
             data.isPro is bool &&
             data.requestCount is int;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'vehicles', 'report', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.vehicles is list &&
             data.report is string;
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /analyses/{analysisId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
    }
  }
}
